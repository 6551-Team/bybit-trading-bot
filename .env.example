# Copy to .env — never commit real keys.

BYBIT_API_KEY=
BYBIT_API_SECRET=

# true = https://api-testnet.bybit.com
BYBIT_TESTNET=true

# Dry-run: compute signals and log; no orders
DRY_RUN=true

# Linear USDT perpetual symbol
SYMBOL=BTCUSDT

# Candle interval: 1,3,5,15,30,60,120,240,360,720,D,W,M
INTERVAL=15

# EMA trend system (classic MACD-style periods; widely used in trend literature)
FAST_EMA=12
SLOW_EMA=26
ADX_PERIOD=14
ADX_MIN=22

ATR_PERIOD=14
ATR_STOP_MULT=1.75
ATR_TP_MULT=3.5

# Risk: max fraction of wallet USDT equity per trade (used to size qty vs stop distance)
RISK_PER_TRADE=0.005

# Hard cap on order qty (base coin) after risk sizing; also bounded by exchange max
MAX_ORDER_QTY=0.001

# Poll interval ms
POLL_MS=60000
